{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "LexDesk",
    "version": "1.0.3"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "clipboard": {
        "all": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": [
          "https://api.github.com/**",
          "https://api.anthropic.com/**",
          "https://api.openai.com/**",
          "https://raw.githubusercontent.com/**"
        ]
      },
      "dialog": {
        "all": true,
        "save": true
      },
      "fs": {
        "all": false,
        "writeFile": true,
        "readFile": true,
        "scope": ["$DOWNLOAD/**", "$DESKTOP/**"]
      }
    },
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://raw.githubusercontent.com/juliengustinelli-ops/lexdesk/main/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzMjQzNTE1RUE3RTY2MTkKUldRWlpuN3FGVFVrOHlxZ0VlaU1DU2VhWjJmWUMwLzJQYjNZeEhDVlRDWkJGV1dyODdBZUovSnEK"
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "co.lexai.lexdesk",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "LexDesk",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true
      }
    ]
  }
}
